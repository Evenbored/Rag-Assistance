APP_TITLE="RAG Assistance API"
APP_VERSION="0.1.0"
DEBUG=true
BOT_TOKEN="token"
TELEGRAM_WEBHOOK_SECRET="secret_token"
TELEGRAM_ADMIN_IDS="id1,id2,id3"
UPLOAD_DIR="uploads"
ALLOWED_DOCUMENT_EXTENSIONS=".txt,.pdf,.docx"
POSTGRES_HOST="db"
POSTGRES_PORT="5432"
POSTGRES_DB="rag_assistance"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
EMBEDDING_MODEL_NAME="sentence-transformers/all-MiniLM-L6-v2"
EMBEDDING_DIMENSION="384"
LLM_PROVIDER="ollama"
OLLAMA_BASE_URL="http://host.docker.internal:11434"
OLLAMA_MODEL="qwen2.5:7b"
LLM_TIMEOUT_SECONDS="120"
TELEGRAM_WEBHOOK_URL="https://your-domain.com/api/v1/tg/webhook"
WARMUP_EMBEDDING_MODEL=true
DELETE_WEBHOOK_ON_SHUTDOWN=true